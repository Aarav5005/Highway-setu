APP_ENV=development
APP_PORT=3000
APP_BASE_URL=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=highway_setu
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email@gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_WEB_API_KEY=your_web_api_key

GOOGLE_MAPS_API_KEY=your_google_maps_api_key

STORAGE_PROVIDER=s3
STORAGE_BUCKET=highway-setu-assets
STORAGE_REGION=ap-south-1

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=highway-setu-assets

CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081
LOG_LEVEL=info